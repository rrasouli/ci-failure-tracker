export ISSUE_NUMBER=${ISSUE_NUMBER}
export GITHUB_ISSUE_URL=${GITHUB_ISSUE_URL}

# GH_TOKEN in the sandbox is a READ-ONLY scoped app installation token.
# The separate write-enabled PUSH_TOKEN (runner_env) never enters the sandbox.
export GH_TOKEN=${GH_TOKEN}

# Git identity — uses the GitHub App bot user's noreply email so GitHub
# links commits to the bot account (author.type === "Bot").
export GIT_AUTHOR_NAME="fullsend-code"
export GIT_AUTHOR_EMAIL="${GIT_BOT_EMAIL}"
export GIT_COMMITTER_NAME="fullsend-code"
export GIT_COMMITTER_EMAIL="${GIT_BOT_EMAIL}"

# Retry budget — the agent re-runs tests on failure.
export MAX_RETRIES=1

# Hard timeout for the sandbox session in seconds.
export TIMEOUT_SECONDS=1500

# Python toolchain — set up virtualenv paths.
# NOTE: PATH is set via env.sandbox in code.yaml so $PATH expands inside the
# sandbox (expand: true here would resolve it on the runner side).
export VIRTUAL_ENV="/sandbox/workspace/venv"
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1

# Project layout — the dashboard code lives in dashboard/ subdirectory.
export DASHBOARD_DIR="/sandbox/workspace/dashboard"

# SSL certs for sandbox TLS termination.
if [ -f /etc/openshell-tls/ca-bundle.pem ]; then
  export GIT_SSL_CAINFO=/etc/openshell-tls/ca-bundle.pem
  export REQUESTS_CA_BUNDLE=/etc/openshell-tls/ca-bundle.pem
else
  export GIT_SSL_CAINFO=/etc/ssl/certs/ca-certificates.crt
fi
